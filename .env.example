# 数据库连接 (PostgreSQL)
DATABASE_DSN=host=localhost user=postgres password=postgres dbname=movie_reservation port=5432

# 服务器地址
ADDR=:8080

# JWT 密钥
JWT_SECRET_KEY=your-secret-key-change-in-production

# SSL 证书路径 (项目已有自签名证书)
CERT_PATH=config/server.crt
KEY_PATH=config/server.key

# Redis 缓存地址
CACHE_URL=redis://localhost:6379

# 管理员密码
ADMIN_ROLE_PASSWORD=admin123
